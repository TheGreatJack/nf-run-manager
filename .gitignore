# ── Project config (contains credentials) ────────────────────────────────────
.env

# ── Test data (local only, not tracked) ───────────────────────────────────────
data/test_data/

# ── Run outputs (can be large) ────────────────────────────────────────────────
runs/*/workdir/
runs/*/publishDir/
runs/*/outputs/
runs/*/nextflow.log
runs/*/params.yaml

# ── Nextflow cache ────────────────────────────────────────────────────────────
.nextflow/
.nextflow.log*

# ── Nextflow binaries ─────────────────────────────────────────────────────────
nextflow_binaries/

# ── Workflow repo (managed as a separate project) ─────────────────────────────
workflow/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── OS / editor lock files ────────────────────────────────────────────────────
.DS_Store
.~lock.*
