# ── Project config (contains credentials) ────────────────────────────────────
.env

# ── Test data (local only, not tracked) ───────────────────────────────────────
data/test_data/

# ── Run folders (local audit artifacts, not tracked) ─────────────────────────
runs/*/

# ── Nextflow cache ────────────────────────────────────────────────────────────
.nextflow/
.nextflow.log*

# ── Nextflow binaries ─────────────────────────────────────────────────────────
nextflow_binaries/

# ── Workflow repo (managed as a separate project) ─────────────────────────────
workflow/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── OS / editor lock files ────────────────────────────────────────────────────
.DS_Store
.~lock.*
