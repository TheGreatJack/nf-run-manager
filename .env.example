# nf-run-manager — Project Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is sourced by all scripts automatically. It is gitignored
# so your credentials never leave your machine.

# ── AWS CLI ──────────────────────────────────────────────────────────────────
# SSO profile name configured with `aws configure sso`
NF_RUNNER_AWS_PROFILE="your-sso-profile"

# Default AWS region
NF_RUNNER_REGION="us-east-1"

# ── AWS HealthOmics (omics-run.sh) ──────────────────────────────────────────
# Workflow ID and version registered in HealthOmics
NF_RUNNER_WORKFLOW_ID=""
NF_RUNNER_WORKFLOW_VERSION=""

# S3 URI where HealthOmics writes run outputs
NF_RUNNER_OMICS_OUTPUT_URI="s3://your-bucket/"

# IAM role ARN that HealthOmics assumes to access S3 and ECR
NF_RUNNER_ROLE_ARN=""

# ── AWS Batch (batch-run.sh) ────────────────────────────────────────────────
# GitHub org/repo of the Nextflow pipeline
NF_RUNNER_PIPELINE="your-org/your-pipeline"

# Git branch or tag to run
NF_RUNNER_REVISION="main"

# S3 work directory for Nextflow intermediate files
NF_RUNNER_BATCH_WORKDIR="s3://your-bucket/batch-work/"

# S3 URI for pipeline results
NF_RUNNER_BATCH_OUTPUT_URI="s3://your-bucket/batch-results/"
